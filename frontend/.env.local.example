# =============================================================================
# Environment Variables for Talent Acquisition Accelerator Frontend
# =============================================================================

# =============================================================================
# API Configuration
# =============================================================================

# AWS API Gateway URL (required for production)
# Get this from AWS API Gateway after deployment
# Example: https://abc123.execute-api.us-east-1.amazonaws.com/prod
NEXT_PUBLIC_API_GATEWAY_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# API Key for AWS API Gateway (optional, if API key is required)
NEXT_PUBLIC_API_KEY=

# =============================================================================
# Development Mode
# =============================================================================

# Use mock API for local development without AWS (true/false)
# Set to 'true' for local development without AWS costs
# Set to 'false' for production or when testing with real AWS
NEXT_PUBLIC_USE_MOCK_API=true

# Demo mode (set to true for demo scenarios with pre-loaded data)
NEXT_PUBLIC_DEMO_MODE=false

# =============================================================================
# Application Configuration
# =============================================================================

# Application environment (development/staging/production)
NEXT_PUBLIC_APP_ENV=development

# Enable debug logging (true/false)
NEXT_PUBLIC_DEBUG=false

# =============================================================================
# Feature Flags
# =============================================================================

# Enable analytics (true/false)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable error reporting (true/false)
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false

# =============================================================================
# Instructions
# =============================================================================

# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
#
# 2. For local development (no AWS):
#    - Set NEXT_PUBLIC_USE_MOCK_API=true
#    - Leave NEXT_PUBLIC_API_GATEWAY_URL as placeholder
#
# 3. For AWS integration:
#    - Deploy backend to AWS (see infrastructure/ folder)
#    - Get API Gateway URL from AWS Console
#    - Set NEXT_PUBLIC_API_GATEWAY_URL to your API Gateway URL
#    - Set NEXT_PUBLIC_USE_MOCK_API=false
#    - Add API key if required
#
# 4. Restart Next.js dev server after changing environment variables:
#    npm run dev
#
# =============================================================================
# Security Notes
# =============================================================================
#
# - Never commit .env.local to git (it's in .gitignore)
# - API keys should be kept secret
# - Use different API keys for development/staging/production
# - For production, set environment variables in Vercel dashboard
#
# =============================================================================

